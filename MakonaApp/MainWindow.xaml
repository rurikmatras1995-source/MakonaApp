<Window x:Class="MakonaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="МАКОНА - Металлоконструкции" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5E6D3">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхний баннер -->
        <Border Grid.Row="0" Height="90">
            <Border.Background>
                <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                    <GradientStop Color="#C97B5A" Offset="0"/>
                    <GradientStop Color="#D4A373" Offset="0.5"/>
                    <GradientStop Color="#C97B5A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔩" FontSize="45" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock Text="МАКОНА" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Производство металлоконструкций" FontSize="14" Foreground="#F5E6D3" HorizontalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="🏗️" FontSize="45" Margin="15,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель навигации -->
        <Border Grid.Row="1" Background="#D4B896" Padding="12" BorderBrush="#C97B5A" BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnCustomers" Width="140" Height="45" Margin="8" Click="btnCustomers_Click"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Заказчики" FontSize="14"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnProducts" Width="140" Height="45" Margin="8" Click="btnProducts_Click"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔧" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Продукция" FontSize="14"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnOrders" Width="140" Height="45" Margin="8" Click="btnOrders_Click"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Заказы" FontSize="14"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnEmployees" Width="140" Height="45" Margin="8" Click="btnEmployees_Click"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👷" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Сотрудники" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Область для страниц -->
        <Frame x:Name="MainFrame" Grid.Row="2" NavigationUIVisibility="Hidden" Margin="15"/>

        <!-- Строка состояния -->
        <Border Grid.Row="3" Background="#D4B896" Padding="8" BorderBrush="#C97B5A" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="StatusText" Text="✅ Готово" Foreground="#4A3B2C" FontSize="12"/>
                <TextBlock Text="МАКОНА - Производство металлоконструкций" 
                           Foreground="#8B6914" FontSize="12" HorizontalAlignment="Center"/>
                <TextBlock Text="2025" Foreground="#8B6914" FontSize="12" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>