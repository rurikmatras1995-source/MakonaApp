<Page x:Class="MakonaApp.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы" Background="#F5E6D3">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="15">
            <StackPanel>
                <TextBlock Text="📦 ЗАКАЗЫ НА МЕТАЛЛОКОНСТРУКЦИИ" FontSize="20" FontWeight="Bold" 
                           Foreground="#C97B5A" HorizontalAlignment="Center"/>
                <TextBlock Text="Управление заказами и отслеживание статусов" 
                           FontSize="12" Foreground="#8B6914" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15" Margin="0,15,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="📊 Фильтр по статусу:" Grid.Column="0" VerticalAlignment="Center" 
                           FontWeight="Bold" FontSize="14" Margin="0,0,15,0" Foreground="#4A3B2C"/>
                <ComboBox x:Name="cbStatusFilter" Grid.Column="1" Height="35"
                          SelectionChanged="cbStatusFilter_SelectionChanged">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="Новый"/>
                    <ComboBoxItem Content="В производстве"/>
                    <ComboBoxItem Content="Готов"/>
                    <ComboBoxItem Content="Отгружен"/>
                    <ComboBoxItem Content="Отменен"/>
                </ComboBox>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="5">
            <DataGrid x:Name="dgOrders" AutoGenerateColumns="True" IsReadOnly="True">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding status}" Value="Отгружен">
                                <Setter Property="Background" Value="#D4E8C2"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding status}" Value="Отменен">
                                <Setter Property="Background" Value="#E8B8B8"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>
    </Grid>
</Page>