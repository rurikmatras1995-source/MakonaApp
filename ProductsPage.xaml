<Page x:Class="MakonaApp.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Продукция" Background="#F5E6D3">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="15">
            <StackPanel>
                <TextBlock Text="🔧 КАТАЛОГ МЕТАЛЛОКОНСТРУКЦИЙ" FontSize="20" FontWeight="Bold" 
                           Foreground="#C97B5A" HorizontalAlignment="Center"/>
                <TextBlock Text="Фермы, колонны, балки, заборы, ворота" 
                           FontSize="12" Foreground="#8B6914" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="5" Margin="0,15,0,0">
            <DataGrid x:Name="dgProducts" AutoGenerateColumns="True" IsReadOnly="True"/>
        </Border>
    </Grid>
</Page>